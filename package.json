{
  "name": "trello-clone-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "generate:api-types": "openapi-typescript http://localhost:8080/api/docs/openapi.json -o src/types/api.d.ts"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.18.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-3-fullscreen-image-directive-plugin": "^1.0.4",
    "vue-router": "^5.1.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.3.7"
  }
}
